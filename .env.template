# URL de la conexión a la base de datos PostgreSQL, cambiar los valores según tu configuración local
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"

# URL de la base de datos sombra usada por Prisma para validar migraciones, debe apuntar a una BD distinta en el mismo servidor
SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/database_name_shadow"

# Servidor
PORT=3000
NODE_ENV=development

# JWT configuración para la autenticación, cambiar la clave secreta y el tiempo de expiración según tus necesidades
JWT_SECRET="example_secret_key_for_signing_tokens_change_this_in_production"
JWT_EXPIRES_IN="1d"
